-- 测试MML配置文件
-- 用于演示MML配置管理系统

-- ===== SUBRACK =====
SET SUBRACK:ID=1,NAME="Subrack_01",TYPE="OSN9800",LOCATION="Room_A";
SET SUBRACK:ID=2,NAME="Subrack_02",TYPE="OSN9800",LOCATION="Room_B";
ADD SUBRACK:ID=3,NAME="Subrack_03",TYPE="OSN8800",LOCATION="Room_C";

-- ===== BOARD =====
SET BOARD:ID=1,SLOT=1,SUBRACK_ID=1,TYPE="LSC",VERSION="V1.0";
SET BOARD:ID=2,SLOT=2,SUBRACK_ID=1,TYPE="LSC",VERSION="V1.0";
ADD BOARD:ID=3,SLOT=3,SUBRACK_ID=1,TYPE="CQ2",VERSION="V2.0";
SET BOARD:ID=4,SLOT=1,SUBRACK_ID=2,TYPE="LSC",VERSION="V1.0";
ADD BOARD:ID=5,SLOT=2,SUBRACK_ID=2,TYPE="CQ2",VERSION="V2.0";

-- ===== LTE_CELL =====
SET LTE_CELL:ID=1,NAME="Cell_01",PCI=100,FREQ=1800,BAND=3;
SET LTE_CELL:ID=2,NAME="Cell_02",PCI=101,FREQ=1800,BAND=3;
SET LTE_CELL:ID=3,NAME="Cell_03",PCI=102,FREQ=2100,BAND=1;
ADD LTE_CELL:ID=4,NAME="Cell_04",PCI=103,FREQ=2100,BAND=1;
SET LTE_CELL:ID=5,NAME="Cell_05",PCI=104,FREQ=2600,BAND=7;

-- ===== NBRRELATION =====
SET NBRRELATION:ID=1,SRC_CELL=1,DST_CELL=2,HOTHRESH=-95;
SET NBRRELATION:ID=2,SRC_CELL=2,DST_CELL=1,HOTHRESH=-95;
ADD NBRRELATION:ID=3,SRC_CELL=1,DST_CELL=3,HOTHRESH=-90;
SET NBRRELATION:ID=4,SRC_CELL=3,DST_CELL=1,HOTHRESH=-90;
SET NBRRELATION:ID=5,SRC_CELL=2,DST_CELL=3,HOTHRESH=-92;

-- ===== CELLPARAM =====
SET CELLPARAM:ID=1,CELL_NAME="Cell_01",TX_POWER=46,RSRP_BIAS=3;
SET CELLPARAM:ID=2,CELL_NAME="Cell_02",TX_POWER=46,RSRP_BIAS=3;
SET CELLPARAM:ID=3,CELL_NAME="Cell_03",TX_POWER=43,RSRP_BIAS=5;
ADD CELLPARAM:ID=4,CELL_NAME="Cell_04",TX_POWER=43,RSRP_BIAS=5;
SET CELLPARAM:ID=5,CELL_NAME="Cell_05",TX_POWER=40,RSRP_BIAS=6;
SET CELLPARAM:ID=6,CELL_NAME="Cell_06",TX_POWER=40,REMARKS="特殊值,含逗号";
